# .yamllint — YAML formatting rules
# Works alongside ansible-lint

---
extends: default

rules:
  line-length:
    max: 160               # relaxed line length (Ansible task names can be long)
    level: warning

  truthy:
    allowed-values:
      - "true"
      - "false"
      - "yes"
      - "no"               # Ansible historically uses yes/no heavily; allow it
    check-keys: false

  comments:
    min-spaces-from-content: 1

  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

  octal-values:
    forbid-implicit-octal: true   # forbid implicit octal (file modes must be quoted)
    forbid-explicit-octal: false
