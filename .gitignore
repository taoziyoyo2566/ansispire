# Vault 密码文件 — 绝对不能提交
.vault_pass
*.vault_pass

# vault.yml 明文文件 — 必须加密后才能提交，建议直接排除
# 如果你决定提交加密后的 vault.yml，删除下面这行
inventory/**/vault.yml

# Ansible 运行产物
*.retry

# fact 缓存
.facts/
fact_cache/
/tmp/ansible_facts_cache/

# 日志
*.log

# 编辑器
.idea/
.vscode/
*.swp
*~

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
*.egg-info/
uv.lock

# Molecule 产物
.molecule/

# 本地安装的 collections（由 ansible-galaxy install -r requirements.yml 生成）
collections/

# ansible-navigator 产物
.cache/

# 控制面（Semaphore）本地环境文件
controller/semaphore/.env

# Round 8: RBAC demo user credentials (random-generated at bootstrap)
controller/rbac/users.yml
# Round 8: audit sink persisted JSONL + rotated logs
controller/audit/data/
