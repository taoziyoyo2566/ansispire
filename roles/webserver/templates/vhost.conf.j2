{# vhost.conf.j2 — 每个 nginx_vhosts 条目渲染一个文件
   item 由 loop 传入（见 vhosts.yml）#}
{{ ansible_managed }}

{# HTTP server block — 强制跳转 HTTPS（如果启用了 SSL）#}
{% if item.ssl | default(false) %}
server {
    listen 80;
    server_name {{ item.name }};
    return 301 https://$host$request_uri;
}
{% endif %}

server {
{% if item.ssl | default(false) %}
    listen 443 ssl http2;
{% else %}
    listen 80;
{% endif %}
    server_name {{ item.name }};
    root {{ item.root }};
    index index.html index.htm{% if item.php_fpm | default(false) %} index.php{% endif %};

    access_log {{ webserver__log_dir }}/{{ item.name }}_access.log main;
    error_log  {{ webserver__log_dir }}/{{ item.name }}_error.log warn;

{% if item.ssl | default(false) %}
    # ── TLS ───────────────────────────────────────────────────────────────────
    ssl_certificate     {{ item.ssl_cert }};
    ssl_certificate_key {{ item.ssl_key }};
    ssl_stapling        on;
    ssl_stapling_verify on;

    # HSTS
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
{% endif %}

    # ── 安全 headers ──────────────────────────────────────────────────────────
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

{% if item.allowed_ips is defined %}
    # ── IP 白名单 ──────────────────────────────────────────────────────────────
{% for ip in item.allowed_ips %}
    allow {{ ip }};
{% endfor %}
    deny all;
{% endif %}

    # ── 静态资源缓存 ──────────────────────────────────────────────────────────
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|woff2)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

{% if item.php_fpm | default(false) %}
    # ── PHP-FPM ───────────────────────────────────────────────────────────────
    location ~ \.php$ {
        fastcgi_pass unix:{{ item.php_fpm_socket }};
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }
{% endif %}

    location / {
        try_files $uri $uri/ =404;
    }

    # 禁止访问隐藏文件
    location ~ /\. {
        deny all;
    }
}
