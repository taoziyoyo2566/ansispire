{# nginx.conf.j2 — demonstrates advanced Jinja2 usage #}
{{ ansible_managed }}

user  {{ webserver__nginx_user }};
worker_processes  {{ webserver__worker_processes }};
pid  {{ webserver__nginx_pid }};

# Dynamic reference to ansible facts
# ansible_processor_vcpus: CPU core count collected from the target host
# Tip: apply the | int filter for type safety
worker_rlimit_nofile  {{ [webserver__worker_connections * 2, 65535] | min }};

error_log  /var/log/nginx/error.log warn;

events {
    worker_connections  {{ webserver__worker_connections }};
    multi_accept  on;
    use  epoll;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    server_tokens  {{ webserver__server_tokens }};

    # ── Log format ────────────────────────────────────────────────────────────
    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for"';

    access_log  {{ webserver__log_dir }}/access.log  main;

    # ── Performance ───────────────────────────────────────────────────────────
    sendfile        on;
    tcp_nopush      on;
    tcp_nodelay     on;
    keepalive_timeout  {{ webserver__keepalive_timeout }};
    client_max_body_size  {{ webserver__client_max_body_size }};

    # ── Gzip compression ──────────────────────────────────────────────────────
{% if webserver__gzip_enabled %}
    gzip  on;
    gzip_vary  on;
    gzip_proxied  any;
    gzip_comp_level  6;
    gzip_types
{%- for mime in webserver__gzip_types %}
        {{ mime }}
{%- endfor %};
{% endif %}

    # ── Global SSL configuration ──────────────────────────────────────────────
    ssl_protocols  {{ webserver__ssl_protocols }};
    ssl_ciphers  {{ webserver__ssl_ciphers }};
    ssl_prefer_server_ciphers  {{ webserver__ssl_prefer_server_ciphers }};
    ssl_session_cache  shared:SSL:10m;
    ssl_session_timeout  10m;

    # Load every vhost config under sites-enabled
    include  /etc/nginx/sites-enabled/*.conf;
    include  /etc/nginx/conf.d/*.conf;
}
