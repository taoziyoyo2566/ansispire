{# motd.j2
   {{ ansible_managed }} — 此文件由 Ansible 管理，请勿手动修改
   使用内置 Jinja2 特性（不依赖自定义 filter_plugins），确保 role 可独立复用 #}
{{ ansible_managed }}

{# 内联定义环境标签映射，无需外部过滤器 #}
{%- set _env_badges = {
  'production':  '[PROD]',
  'staging':     '[STAGING]',
  'development': '[DEV]',
  'testing':     '[TEST]'
} -%}
{%- set _env_label = _env_badges[env] if env is defined and env in _env_badges
    else '[' + (env | default('UNKNOWN') | upper) + ']' -%}

╔══════════════════════════════════════════════════════════╗
║  {{ common__motd_message | truncate(54, True) | center(54) }}  ║
╠══════════════════════════════════════════════════════════╣
║                                                          ║
║  Hostname   : {{ inventory_hostname | truncate(42) | ljust(42) }}║
║  Environment: {{ _env_label | ljust(42) }}║
║  OS         : {{ (ansible_distribution + ' ' + ansible_distribution_version) | truncate(42) | ljust(42) }}║
║  IPv4       : {{ ansible_default_ipv4.address | default('N/A') | ljust(42) }}║
║  Ansible    : {{ ansible_version.full | ljust(42) }}║
║                                                          ║
╚══════════════════════════════════════════════════════════╝

{% if env | default('') == 'production' %}
⚠  PRODUCTION — Unauthorized access is strictly prohibited.
{% elif env | default('') == 'staging' %}
ℹ  STAGING — For testing only.
{% else %}
ℹ  Environment: {{ _env_label }}
{% endif %}

{%- if ssh_allowed_users | default([]) | length > 0 %}
Authorized users: {{ ssh_allowed_users | join(', ') }}
{% endif %}
