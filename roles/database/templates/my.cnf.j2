{{ ansible_managed }}

[mysqld]
# ── Basics ────────────────────────────────────────────────────────────────────
port            = {{ database__mysql_port }}
bind-address    = {{ database__mysql_bind_address }}
datadir         = {{ database__mysql_datadir }}
socket          = /var/run/mysqld/mysqld.sock
pid-file        = /var/run/mysqld/mysqld.pid

# ── Character set ─────────────────────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ── Performance ───────────────────────────────────────────────────────────────
innodb_buffer_pool_size = {{ database__mysql_innodb_buffer_pool_size }}
innodb_log_file_size    = {{ database__mysql_innodb_log_file_size | default('128M') }}
max_connections         = {{ database__mysql_max_connections }}
max_allowed_packet      = 64M
thread_cache_size       = 8

# ── Logs ──────────────────────────────────────────────────────────────────────
log_error               = {{ database__mysql_log_dir }}/error.log
slow_query_log          = 1
slow_query_log_file     = {{ database__mysql_log_dir }}/slow.log
long_query_time         = 2

# ── Replication (rendered conditionally based on the db_role host var) ────────
{% if db_role is defined and db_role == 'primary' %}
# Primary node configuration
server-id         = 1
log_bin           = {{ database__mysql_datadir }}/mysql-bin
binlog_format     = ROW
expire_logs_days  = 7
{% elif db_role is defined and db_role == 'replica' %}
# Replica node configuration
server-id         = {{ groups['dbservers'].index(inventory_hostname) + 10 }}
relay-log         = {{ database__mysql_datadir }}/relay-bin
read_only         = 1
{% endif %}
