{
  "rules": [
    {
      "name": "Remediation: Disk Full",
      "cooldown": 600,
      "condition": {
        "object_type": "task",
        "description_contains": "Disk Full"
      },
      "actions": [
        {
          "type": "semaphore_api",
          "project_name": "ansispire",
          "template_name": "Auto Remediation: Disk Cleanup",
          "name": "Auto Remediation: Disk Cleanup"
        }
      ]
    },
    {
      "name": "Remediation: DB Connection Failure",
      "enabled": false,
      "_disabled_reason": "playbooks/remediation/db_failover.yml is a placeholder (debug-only). Re-enable after a real failover playbook ships. Tracked under TASK-001 follow-up.",
      "cooldown": 900,
      "condition": {
        "description_contains": "database connection failed"
      },
      "actions": [
        {
          "type": "webhook",
          "name": "DB Alert",
          "url": ""
        },
        {
          "type": "semaphore_api",
          "project_name": "ansispire",
          "template_name": "Auto Remediation: DB Failover",
          "name": "DB Failover"
        }
      ]
    }
  ]
}
