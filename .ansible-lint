---
# .ansible-lint — Configuration for Ansispire
# Docs: https://ansible.readthedocs.io/projects/lint/configuring/

profile: production

# Exclude internal and cache directories
exclude_paths:
  - .git/
  - .venv/
  - .cache/
  - molecule/
  - collections/
  - roles/geerlingguy.docker/

# Rules to skip or treat as warnings
warn_list:
  - experimental

# Strictly follow variable naming conventions
var_naming_pattern: "^[a-z_][a-z0-9_]*$"

# Ensure we use default rules and FQCN
use_default_rules: true

# Note: YAML formatting is handled by .yamllint. 
# The nested 'yaml:' section is deprecated in recent ansible-lint versions.
