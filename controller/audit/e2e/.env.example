# controller/audit/e2e/.env.example — sample env for the disposable e2e stack.
#
# Setup:
#   cp controller/audit/e2e/.env.example controller/audit/e2e/.env
#   # edit if you want a different password (default works fine — stack is
#   # localhost-bound and torn down after each run)
#
# .env is gitignored. Ports are intentionally hardcoded here (NOT rendered
# from config/ports.yml) so the e2e stack stays trivially reproducible
# without depending on the host's ports-sync state.

SEMAPHORE_PORT=3320
AUDIT_PORT=3330

# Image tags pinned for the e2e harness — these are intentionally NOT
# rendered from config/manifest.yml; e2e stays trivially reproducible
# regardless of the host's manifest-sync state.
SEMAPHORE_IMAGE_TAG=v2.18.2
AUDIT_IMAGE_TAG=3.12-alpine

SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=e2e_disposable_pw

TZ=UTC
