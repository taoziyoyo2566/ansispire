# controller/semaphore/.env.example — sample environment for the Semaphore
# control plane.
#
# Three-file layout:
#   - config/manifest.yml                       (SSOT for host ports + image tags)
#   - controller/semaphore/.env                 (this file's runtime copy;
#                                                user-editable: admin/timezone)
#   - controller/semaphore/.secrets             (machine-generated by
#                                                bootstrap.yml; holds
#                                                SEMAPHORE_API_TOKEN)
#
# Setup:
#   cp controller/semaphore/.env.example controller/semaphore/.env
#   vim controller/semaphore/.env               # set SEMAPHORE_ADMIN_PASSWORD
#   make controller-up                          # auto-runs manifest-sync
#   make controller-bootstrap                   # mints API token → .secrets
#
# Manifest lines (SEMAPHORE_PORT, SEMAPHORE_IMAGE_TAG, AUDIT_PORT,
# AUDIT_IMAGE_TAG, AUDIT_PYTHON_BASE_TAG) are managed by manifest-sync —
# DO NOT edit them by hand. Edit config/manifest.yml then `make manifest-sync`.
# Semantics: AUDIT_IMAGE_TAG tags our OWN baked images
# (ansispire/audit-sink, ansispire/audit-reactor); AUDIT_PYTHON_BASE_TAG is
# the upstream `python:VERSION` tag for audit-relay (not baked).

# ── Web root ───────────────────────────────────────────────────────────
# If accessed behind a reverse proxy (e.g. under /semaphore/), set WEB_ROOT.
# Leave empty when accessed directly.
SEMAPHORE_WEB_ROOT=

# ── Admin account (created on first boot) ──────────────────────────────
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_NAME=Administrator
SEMAPHORE_ADMIN_EMAIL=admin@localhost

# ! Must be changed to a strong password; do NOT commit to git
#   (.env is already in .gitignore)
SEMAPHORE_ADMIN_PASSWORD=changeme_please

# ── Timezone ───────────────────────────────────────────────────────────
TZ=Asia/Shanghai

# ── Security keys (cookie persistence + access-key encryption) ─────────
# Upstream Semaphore uses these three keys for:
#   ACCESS_KEY_ENCRYPTION  — encryption-at-rest for stored AccessKeys
#                             (vault placeholders, SSH keys, …)
#   COOKIE_HASH            — HMAC of session cookies
#   COOKIE_ENCRYPTION      — symmetric encryption of session cookies
# Leaving them empty makes Semaphore mint ephemeral keys each restart;
# every restart invalidates all sessions AND breaks decryption of any
# already-stored AccessKey. For Path A (hub deploy) the keys are
# auto-generated once and persisted under
# /var/lib/ansispire/state/.security_keys — DO NOT touch them by hand.
# For Path B (local docker-compose), generate locally and paste in:
#   head -c32 /dev/urandom | base64    # × 3
# Without the 3 lines below set, expect cookie + AccessKey instability.
SEMAPHORE_ACCESS_KEY_ENCRYPTION=
SEMAPHORE_COOKIE_HASH=
SEMAPHORE_COOKIE_ENCRYPTION=

# ── Manifest (managed by manifest-sync — do not edit; edit config/manifest.yml) ─
# SEMAPHORE_PORT, SEMAPHORE_IMAGE_TAG, AUDIT_PORT, AUDIT_IMAGE_TAG,
# AUDIT_PYTHON_BASE_TAG are written below by `make manifest-sync`.
